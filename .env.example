# --- LLM (endpoint OpenAI-compatible, es. vLLM su Colab via tunnel HTTPS) ---
OPENAI_BASE_URL=                 # es. https://xyz.trycloudflare.com/v1
OPENAI_API_KEY=                  # stessa api-key passata a vLLM (--api-key)
LLM_MODEL=Qwen/Qwen3-32B

# --- Database ---
POSTGRES_DB=agroagent
POSTGRES_USER=agroagent
POSTGRES_PASSWORD=               # generare: openssl rand -hex 16

# --- MCP ---
MCP_AUTH_TOKEN=                  # bearer token agent_service -> mcp_server: openssl rand -hex 32
MCP_SERVER_URL=http://mcp_server:8001/mcp
AGENT_SERVICE_URL=http://agent_service:8002

# --- Simulazione ---
# A velocità ×1, 1 giorno simulato dura SIM_DAY_REAL_MINUTES minuti reali.
SIM_DAY_REAL_MINUTES=5
SIM_HOURS_PER_TICK=1            # ore simulate per tick (granularità; ↑ = meno carico)
DEFAULT_FIELD_ROWS=10
DEFAULT_FIELD_COLS=10
IMAGE_BASE_PATH=/app/data/images

# --- Memoria LLM ---
CONTEXT_MAX_TOKENS=8000         # soglia per il riassunto automatico della history
# Embeddings per la ricerca semantica nello Store (opzionale: se vuoti,
# memoria a lungo termine senza ricerca semantica).
EMBEDDINGS_BASE_URL=            # es. endpoint OpenAI-compatibile /v1 che serve embeddings
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=               # es. nomic-embed-text, bge-m3, text-embedding-3-small
EMBEDDINGS_DIMS=1536
